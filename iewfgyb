-- 1.
DELIMITER $$
CREATE FUNCTION CalculateYearsWorked(hire_date DATE) 
RETURNS INT
DETERMINISTIC
BEGIN
    RETURN TIMESTAMPDIFF(YEAR, hire_date, CURDATE());
END $$
DELIMITER ;


-- 2.
DELIMITER $$
CREATE FUNCTION CalculateTotalPrice(quantity INT, unit_price DECIMAL(10,2)) 
RETURNS DECIMAL(10,2)
DETERMINISTIC
BEGIN
    RETURN quantity * unit_price;
END $$
DELIMITER ;


-- 3 and 5.
DELIMITER $$
CREATE FUNCTION CategorizeEmployeeTenure(hire_date DATE) 
RETURNS VARCHAR(20)
DETERMINISTIC
BEGIN
    DECLARE tenure_years INT;
    SET tenure_years = TIMESTAMPDIFF(YEAR, hire_date, CURDATE());
    
    IF tenure_years < 3 THEN
        RETURN 'Junior';
    ELSEIF tenure_years >= 3 AND tenure_years <= 7 THEN
        RETURN 'Mid-level';
    ELSE
        RETURN 'Senior';
    END IF;
END $$
DELIMITER ;



-- 4.
DELIMITER $$
CREATE FUNCTION GetStockStatus(stock_qty INT) 
RETURNS VARCHAR(20)
DETERMINISTIC
BEGIN
    IF stock_qty <= 0 THEN
        RETURN 'Out of Stock';
    ELSEIF stock_qty < 20 THEN
        RETURN 'Low Stock';
    ELSE
        RETURN 'In Stock';
    END IF;
END $$
DELIMITER ;


