DELIMITER $$
CREATE FUNCTION GetDepartmentSalaryBudget(p_dept_id INT) RETURNS DECIMAL(10,2)
READS SQL DATA
BEGIN
    DECLARE v_total DECIMAL(10,2);
    
    -- Add up all salaries for the specific department
    SELECT SUM(salary) INTO v_total FROM employees WHERE dept_id = p_dept_id;
    
    -- IFNULL returns 0 if the department has no employees/salaries
    RETURN IFNULL(v_total, 0);
END $$
