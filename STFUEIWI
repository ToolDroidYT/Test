1. Procedure: Add Employee with Validation + Transaction
DELIMITER $$
CREATE PROCEDURE AddEmployee(IN p_emp_id INT, IN p_dept_id INT, IN p_salary DECIMAL(10,2))
BEGIN
    -- Start a transaction to group operations
    START TRANSACTION;
    
    -- Check if employee already exists
    IF (SELECT COUNT(*) FROM employees WHERE emp_id = p_emp_id) > 0 THEN
        -- If yes, cancel everything
        ROLLBACK;
    ELSE
        -- If no, insert the new employee
        INSERT INTO employees (emp_id, dept_id, salary) VALUES (p_emp_id, p_dept_id, p_salary);
        -- Increase the department's employee count by 1
        UPDATE departments SET emp_count = emp_count + 1 WHERE dept_id = p_dept_id;
        -- Save the changes permanently
        COMMIT;
    END IF;
END $$
DELIMITER ;

2. Procedure: Increase Salary with Business Rule
DELIMITER $$
CREATE PROCEDURE IncreaseSalary(IN p_emp_id INT, IN p_percent DECIMAL(5,2))
BEGIN
    -- Block any increase over 20%
    IF p_percent > 20.00 THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Error: Cannot increase salary by more than 20%';
    ELSE
        -- Calculate and update the new salary
        UPDATE employees 
        SET salary = salary + (salary * (p_percent / 100)) 
        WHERE emp_id = p_emp_id;
    END IF;
END $$
DELIMITER ;

3. Procedure: Transfer Employee (Transaction Control)
DELIMITER $$
CREATE PROCEDURE TransferEmployee(IN p_emp_id INT, IN p_new_dept_id INT)
BEGIN
    DECLARE v_old_dept_id INT;
    
    START TRANSACTION;
    
    -- Find the employee's current department
    SELECT dept_id INTO v_old_dept_id FROM employees WHERE emp_id = p_emp_id;
    
    -- Only transfer if they are actually moving to a different department
    IF v_old_dept_id != p_new_dept_id THEN
        -- Move employee to new department
        UPDATE employees SET dept_id = p_new_dept_id WHERE emp_id = p_emp_id;
        -- Remove 1 from old department count
        UPDATE departments SET emp_count = emp_count - 1 WHERE dept_id = v_old_dept_id;
        -- Add 1 to new department count
        UPDATE departments SET emp_count = emp_count + 1 WHERE dept_id = p_new_dept_id;
    END IF;
    
    COMMIT;
END $$
DELIMITER ;

4. Function: Calculate Annual Salary
DELIMITER $$
CREATE FUNCTION CalculateAnnualSalary(p_emp_id INT) RETURNS DECIMAL(10,2)
READS SQL DATA
BEGIN
    DECLARE v_monthly_salary DECIMAL(10,2);
    
    -- Get the employee's monthly salary
    SELECT salary INTO v_monthly_salary FROM employees WHERE emp_id = p_emp_id;
    
    -- Multiply by 12 months. IFNULL prevents returning a blank error if no salary exists.
    RETURN IFNULL(v_monthly_salary * 12, 0);
END $$
DELIMITER ;

5. Function: Tax Calculation
DELIMITER $$
CREATE FUNCTION CalculateTax(p_emp_id INT) RETURNS DECIMAL(10,2)
READS SQL DATA
BEGIN
    DECLARE v_salary DECIMAL(10,2);
    DECLARE v_tax DECIMAL(10,2);
    
    SELECT salary INTO v_salary FROM employees WHERE emp_id = p_emp_id;
    
    -- Apply tax rules based on salary brackets
    IF v_salary < 5000 THEN
        SET v_tax = v_salary * 0.05;
    ELSEIF v_salary <= 8000 THEN
        SET v_tax = v_salary * 0.10;
    ELSE
        SET v_tax = v_salary * 0.15;
    END IF;
    
    RETURN IFNULL(v_tax, 0);
END $$
DELIMITER ;

6. Trigger: Prevent Negative Salary
DELIMITER $$
CREATE TRIGGER PreventNegativeSalary
BEFORE INSERT ON employees
FOR EACH ROW
BEGIN
    -- NEW.salary refers to the salary value being inserted
    IF NEW.salary < 0 THEN
        -- Stop the insertion and throw an error
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Error: Salary cannot be negative';
    END IF;
END $$
DELIMITER ;

7. Trigger: Prevent Deleting Last Employee in Department
DELIMITER $$
CREATE TRIGGER PreventDeleteLastEmployee
BEFORE DELETE ON employees
FOR EACH ROW
BEGIN
    -- OLD.dept_id refers to the department of the employee being deleted
    IF (SELECT COUNT(*) FROM employees WHERE dept_id = OLD.dept_id) <= 1 THEN
        -- Stop the deletion if count is 1 or less
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Error: Cannot delete the last employee';
    END IF;
END $$
DELIMITER ;

