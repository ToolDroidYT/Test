6. Trigger: Department Salary Budget Protection
DELIMITER $$
CREATE TRIGGER ProtectDeptSalaryBudget
BEFORE INSERT ON employees
FOR EACH ROW
BEGIN
    DECLARE v_current_budget DECIMAL(10,2);
    
    -- Calculate current total budget before the new employee is added
    SELECT IFNULL(SUM(salary), 0) INTO v_current_budget 
    FROM employees 
    WHERE dept_id = NEW.dept_id;
    
    -- Check if adding the new salary exceeds 50,000
    IF (v_current_budget + NEW.salary) > 50000 THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Error: Adding this employee exceeds the 50,000 budget';
    END IF;
END $$
DELIMITER ;

7. Trigger: Restrict Department Overload
DELIMITER $$
CREATE TRIGGER RestrictDeptOverload
BEFORE INSERT ON employees
FOR EACH ROW
BEGIN
    -- Check if department already has 10 or more employees
    IF (SELECT COUNT(*) FROM employees WHERE dept_id = NEW.dept_id) >= 10 THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Error: Department is full (10 employees max)';
    END IF;
END $$
DELIMITER ;

