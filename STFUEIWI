DELIMITER $$
CREATE PROCEDURE GenerateDepartmentSalaryReport(IN p_dept_id INT)
BEGIN
    -- Retrieve all required statistics in one query
    SELECT 
        COUNT(emp_id) AS total_employees,
        IFNULL(AVG(salary), 0) AS average_salary,
        IFNULL(MAX(salary), 0) AS highest_salary,
        IFNULL(MIN(salary), 0) AS lowest_salary,
        IFNULL(SUM(salary), 0) AS total_budget
    FROM employees
    WHERE dept_id = p_dept_id;
END $$
DELIMITER ;

